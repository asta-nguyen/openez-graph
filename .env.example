# OpenEZ Graph — Zero-config by default
# No env vars required. SQLite is used automatically.

# Storage model (auto-managed, no config needed):
#   Global registry: ~/.ai-memory-graph/
#   Per-workspace:   <root>/.openez/
#   Workspace hint:  <root>/.openez/workspace.json

# Optional: LLM provider API keys for memory_query retrieval
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# MINIMAX_API_KEY=...

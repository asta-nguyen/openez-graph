# Database (optional - SQLite is default)
# DATABASE_URL=postgres://brain:brain@localhost:5432/brain

# Redis (optional - not used in default flow)
# REDIS_URL=redis://localhost:16379

# Embedding provider (optional - disabled by default)
# Set to "ollama" or "openai" to enable
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

    "@openez-graph/mcp": "workspace:*",
    "@openez-graph/web": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "chokidar": "^4.0.3",
    "commander": "^14.0.0",
    "smol-toml": "^1.6.1",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "zod": "^3.25.76"
  }
